# ==============================================================================
# Knot — Environment Variables
# Copy this file to .env and fill in the values.
# ==============================================================================

# --- Turnkey (Parent Org) ---
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# --- Turnkey (Delegated Signing) ---
# Added as root users in each sub-org to enable server-side signing
TURNKEY_DELEGATED_API_PUBLIC_KEY=
TURNKEY_DELEGATED_API_PRIVATE_KEY=

# --- Solana ---
HELIUS_API_KEY=
SOLANA_NETWORK=mainnet-beta          # mainnet-beta | devnet
SOLANA_RPC_URL=                      # optional: custom RPC URL (overrides Helius)

# --- Helius Webhooks ---
HELIUS_WEBHOOK_SECRET=

# --- Jupiter ---
JUPITER_API_KEY=
JUPITER_REFERRAL_ACCOUNT=            # optional: referral account public key

# --- Kalshi Prediction Markets (optional — leave blank to disable) ---
KALSHI_API_KEY_ID=
KALSHI_RSA_PRIVATE_KEY=              # RSA private key in PEM format
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- Kalshi Admin Wallet (custodial prediction funds) ---
KNOT_KALSHI_ADMIN_KEY_ID=
KNOT_KALSHI_ADMIN_WALLET_ADDRESS=

# --- Meteora Admin Wallet (custodial liquidity provision) ---
KNOT_METEORA_ADMIN_KEY_ID=
KNOT_METEORA_ADMIN_WALLET_ADDRESS=

# --- Fee Collection Wallet ---
KNOT_FEE_WALLET_ADDRESS=             # receives platform fees from transfers/trades

# --- Stats ---
STATS_API_SECRET=
STATS_TOKEN_TTL_SECONDS=300

# --- Auth ---
JWT_SECRET=                          # random 256-bit hex string
OTP_TTL_MINUTES=10
ADMIN_EMAILS=admin@example.com       # comma-separated list of admin emails

# --- Email (Mailtrap) ---
MAILTRAP_API_KEY=

# --- Email (SMTP fallback — optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASS=

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/knot

# --- Server ---
PORT=3000
API_BASE_URL=http://localhost:3000
LOG_LEVEL=info                       # trace | debug | info | warn | error | fatal | silent