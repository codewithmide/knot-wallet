{
  "name": "knot",
  "version": "1.0.0",
  "description": "Solana Agent Wallet - Server-side wallet infrastructure for AI agents",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "patch-package && prisma generate",
    "prestart": "prisma db push",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "solana",
    "wallet",
    "agent",
    "turnkey"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@jup-ag/referral-sdk": "^0.3.0",
    "@meteora-ag/dlmm": "^1.9.3",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@turnkey/crypto": "^2.8.10",
    "@turnkey/sdk-server": "^5.0.3",
    "@turnkey/solana": "^1.1.23",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "dotenv": "^17.3.1",
    "envalid": "^8.1.1",
    "hono": "^4.12.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "patch-package": "^8.0.1",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
